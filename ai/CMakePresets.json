{
  "version": 8,
  "configurePresets": [
    {
      "name": "standalone",
      "displayName": "Standalone",
      "binaryDir": "${sourceDir}/build/standalone",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "wasm",
      "displayName": "WASM build",
      "binaryDir": "${sourceDir}/build/wasm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING":  "FALSE",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
      }
    }
  ],
  "testPresets": [
      {
        "name": "test-all",
        "displayName": "Test All",
        "configurePreset": "standalone",
      }
  ]
}