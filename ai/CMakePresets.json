{
  "version": 8,
  "configurePresets": [
    {
      "name": "standalone",
      "displayName": "Standalone",
      "binaryDir": "${sourceDir}/build/standalone",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "wasm",
      "displayName": "WASM build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/wasm",
      "toolchainFile": "${sourceDir}/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "standalone-release",
      "displayName": "Standalone",
      "configurePreset": "standalone",
      "configuration": "Release"
    },
    {
      "name": "wasm",
      "displayName": "WASM build",
      "configurePreset": "wasm",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-all",
      "displayName": "Test All",
      "configurePreset": "standalone"
    }
  ]
}
